NODE_ENV=development
PORT=3000
HOST=0.0.0.0
REDIS_URL=redis://127.0.0.1:6379
DATA_DIR=.lh-audit
STATIC_DIR=web/dist
WORKER_CONCURRENCY=1
ALLOWED_HOSTS=
MANUAL_CHROME_MODE=connect-only

# Local-only persistent Chrome profile for authenticated/OTP audit tabs.
# Run the API and worker against the SAME Redis so the worker inherits the API's
# boot identity (generated on API startup) — there is no server-instance env var.
# Manual mode requires a non-empty ALLOWED_HOSTS allowlist (above).
MANUAL_CHROME_ENABLED=true
MANUAL_CHROME_PORT=9222
MANUAL_CHROME_PROFILE_DIR=.lh-audit/chrome-profile
MANUAL_CHROME_STARTUP_TIMEOUT_MS=60000
MANUAL_CHROME_MAX_TABS=20
MANUAL_CHROME_MAX_EVIDENCE_FILES=100
MANUAL_CHROME_MAX_EVIDENCE_BYTES=52428800
MANUAL_CHROME_AUTO_OPEN=false

# Auto-open browser when server starts (opens web UI)
SERVER_AUTO_OPEN_BROWSER=true

# Generate 32-byte base64 secrets:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=JBkBIzQoQ7+OaY//Xf7znynYeKBllxQAUSH2Ft7NL2s=
DOWNLOAD_TOKEN_SECRET=4fT3ufmvGgE3Xqng1ixO61tNl2UQONIvFqyLKpd94qM=
