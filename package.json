{
    "name": "lighthouse-audit-tool",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=22.19.0"
    },
    "scripts": {
        "dev": "tsx watch --env-file-if-exists=.env src/server/index.ts",
        "dev:worker": "tsx watch --env-file-if-exists=.env src/worker/index.ts",
        "dev:web": "vite --host 0.0.0.0",
        "build": "pnpm run build:server && pnpm run build:web",
        "build:server": "tsc -p tsconfig.build.json",
        "build:web": "vite build",
        "start": "pnpm run start:all",
        "start:server": "node --env-file-if-exists=.env dist/server/index.js",
        "start:worker": "node --env-file-if-exists=.env dist/worker/index.js",
        "start:all": "concurrently -k -s first \"node --env-file-if-exists=.env dist/server/index.js\" \"node --env-file-if-exists=.env dist/worker/index.js\"",
        "kill:server": "fkill \"dist/server/index.js\" \"src/server/index.ts\" --force --silent",
        "kill:worker": "fkill \"dist/worker/index.js\" \"src/worker/index.ts\" --force --silent",
        "kill:all": "pnpm run kill:worker && pnpm run kill:server",
        "dry-run": "node scripts/clear-audit-queue.mjs --dry-run",
        "clear": "node scripts/clear-audit-queue.mjs",
        "reset": "pnpm run kill:worker && pnpm run clear",
        "test": "vitest run",
        "test:watch": "vitest",
        "smoke:auth": "node scripts/smoke-auth.mjs",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "pnpm run typecheck"
    },
    "dependencies": {
        "bullmq": "^5.78.0",
        "chrome-launcher": "^1.2.1",
        "exceljs": "^4.4.0",
        "fastify": "^5.8.5",
        "ioredis": "^5.10.1",
        "jose": "^5.9.6",
        "lighthouse": "^13.3.0",
        "lucide-react": "^0.475.0",
        "mime-types": "^2.1.35",
        "pino": "^10.3.1",
        "puppeteer-core": "^22.15.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.0",
        "@types/mime-types": "^2.1.4",
        "@types/node": "^22.10.5",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@vitejs/plugin-react": "^6.0.2",
        "concurrently": "^10.0.3",
        "fkill-cli": "^9.0.0",
        "kill-port": "^2.0.1",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.8"
    },
    "packageManager": "pnpm@11.5.2"
}
